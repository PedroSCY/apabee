# Servidor
PORT=3001

# Banco de Dados (string de conexão Supabase Postgres via pgBouncer)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Supabase — URL do projeto (painel: Settings → API → Project URL)
SUPABASE_PROJECT_URL=https://[ref].supabase.co

# Supabase — chave de serviço com acesso admin (painel: Settings → API → service_role)
SUPABASE_SERVICE_KEY=eyJ...

# JWT — segredo para assinar tokens internos (gere com: openssl rand -base64 64)
JWT_SECRET=

# Primeiro acesso, registro padrao no banco.
SEED_ADMIN_EMAIL=seu@email.com
SEED_ADMIN_PASSWORD=SuaSenhaForte!
SEED_ADMIN_NOME=Seu Nome

# ─── Gateway de Pagamento ────────────────────────────────────────────────────
# Seleciona o gateway ativo: 'infinitypay' (padrão, PIX gratuito) | 'asaas'
PAYMENT_GATEWAY_PROVIDER=infinitypay

# InfinityPay — PIX gratuito (gateway padrão)
# Sua InfiniteTag sem o $: veja em app.infinitepay.io → Configurações → Meu perfil
INFINITYPAY_HANDLE=seu-handle
# URL pública do webhook desta API — configurada automaticamente em cada link de cobrança
# Deve ser acessível externamente (ngrok em dev, domínio real em produção)
INFINITYPAY_WEBHOOK_URL=https://sua-api.com/financeiro/webhooks/infinitypay

# Asaas — gateway alternativo (PIX, boleto, cartão) — necessário CPF do associado
# Painel Asaas → Configurações → Integrações → Chave de API
ASAAS_API_KEY=$aact_...
# Painel Asaas → Configurações → Integrações → Notificações → Token de autenticação do webhook
ASAAS_WEBHOOK_TOKEN=
# Sandbox: https://sandbox.asaas.com/api/v3 | Produção: https://api.asaas.com/v3
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

# Mercado Pago — taxa repassada ao associado (%). 0 = associação absorve a taxa.
# Exemplo: 0.99 → mensalidade R$20 gera cobrança de R$20,20; R$20 líquidos entram na conta.
MERCADOPAGO_FEE_PERCENT=0.99