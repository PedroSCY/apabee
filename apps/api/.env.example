# Servidor
PORT=3000

# Banco de Dados (string de conexão Supabase Postgres via pgBouncer)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Supabase — URL do projeto (painel: Settings → API → Project URL)
SUPABASE_PROJECT_URL=https://[ref].supabase.co

# Supabase — chave de serviço com acesso admin (painel: Settings → API → service_role)
SUPABASE_SERVICE_KEY=eyJ...

# JWT — segredo para assinar tokens internos (gere com: openssl rand -base64 64)
JWT_SECRET=
