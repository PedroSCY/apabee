{
  "extends": "@repo/typescript-config/nestjs",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../../",
    "noEmit": true,
    "sourceMap": true,
    "types": ["jest", "node"],
    "paths": {
      "@apa/core": ["../../packages/core/src"],
      "@apa/core/*": ["../../packages/core/src/*"],
      "@apa/shared": ["../../packages/shared/src"],
      "@apa/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src", "test", "prisma.config.ts"],
  "exclude": ["node_modules", "dist"]
}
