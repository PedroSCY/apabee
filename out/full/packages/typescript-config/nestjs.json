{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "isolatedModules": false,
    "removeComments": true,
    "noFallthroughCasesInSwitch": false
  }
}
